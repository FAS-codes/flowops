# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/flowops

# JWT — use long random strings in production (e.g. `openssl rand -hex 32`)
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# This server's own public URL (used to build the OAuth callback in production).
API_URL=http://localhost:4000

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must equal GOOGLE_CALLBACK_URL exactly.
# Leave blank to disable the "Continue with Google" button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Email (SMTP) — e.g. Resend, Mailgun, SendGrid, Gmail app password.
# Leave blank in dev: emails are logged to the console instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=FlowOps <no-reply@flowops.app>
